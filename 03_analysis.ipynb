    "max_r2 = df_capm.loc[df_capm[\"r2\"].idxmax(), [\"name\",\"industry\",\"r2\"]]\n",
    "min_r2 = df_capm.loc[df_capm[\"r2\"].idxmin(), [\"name\",\"industry\",\"r2\"]]\n",
    "\n",
    "print(\"=\"*60)\n",
