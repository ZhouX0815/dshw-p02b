  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 第五部分：CAPM 回归分析\n",
    "\n",
    "### 5.1 模型设定\n",
    "\n",
    "$$r_{i,t} - r_f = \\alpha_i + \\beta_i (r_{m,t} - r_f) + \\varepsilon_{i,t}$$\n",
    "\n",
    "- 无风险利率：年化2.0%，日频换算 $r_f = 0.02 / 252$\n",
    "- 市场收益率：沪深300日对数收益率"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── CAPM 回归 ─────────────────────────────────────────────────────────────────\n",
    "RF_DAILY = 0.02 / 252\n",
    "\n",
    "capm_results = []\n",
    "\n",
    "for s in STOCKS:\n",
    "    code = s[\"code\"]\n",
    "    if code not in ret_wide.columns:\n",
    "        continue\n",
    "    # 合并个股收益率与市场收益率\n",
    "    df_reg = pd.concat([ret_wide[code], hs300[\"hs300_ret\"]], axis=1).dropna()\n",
    "    df_reg.columns = [\"ri\", \"rm\"]\n",
    "    # 超额收益\n",
    "    df_reg[\"excess_i\"] = df_reg[\"ri\"] - RF_DAILY\n",
    "    df_reg[\"excess_m\"] = df_reg[\"rm\"] - RF_DAILY\n",
    "    # OLS 回归\n",
    "    X = sm.add_constant(df_reg[\"excess_m\"])\n",
    "    y = df_reg[\"excess_i\"]\n",
    "    model = sm.OLS(y, X).fit()\n",
    "    alpha   = model.params[\"const\"]\n",
    "    beta    = model.params[\"excess_m\"]\n",
    "    alpha_p = model.pvalues[\"const\"]\n",
    "    beta_ci = model.conf_int().loc[\"excess_m\"].tolist()\n",
    "    r2      = model.rsquared\n",
    "    capm_results.append({\n",
    "        \"code\":    code,\n",
    "        \"name\":    s[\"name\"],\n",
    "        \"industry\":s[\"industry\"],\n",
    "        \"alpha\":   alpha,\n",
    "        \"alpha_p\": alpha_p,\n",
    "        \"beta\":    beta,\n",
    "        \"beta_ci_lo\": beta_ci[0],\n",
    "        \"beta_ci_hi\": beta_ci[1],\n",
    "        \"r2\":      r2,\n",
    "    })\n",
    "\n",
    "df_capm = pd.DataFrame(capm_results)\n",
    "\n",
    "# 打印汇总表格\n",
    "print(\"CAPM 回归结果汇总：\")\n",
    "display_df = df_capm[[\"name\",\"industry\",\"alpha\",\"alpha_p\",\"beta\",\"beta_ci_lo\",\"beta_ci_hi\",\"r2\"]].copy()\n",
    "display_df[\"alpha\"] = display_df[\"alpha\"].map(\"{:.6f}\".format)\n",
    "display_df[\"alpha_p\"] = display_df[\"alpha_p\"].map(\"{:.3f}\".format)\n",
    "display_df[\"beta\"] = display_df[\"beta\"].map(\"{:.4f}\".format)\n",
    "display_df[\"beta_ci\"] = display_df.apply(\n",
    "    lambda r: f\"[{float(r.beta_ci_lo):.3f}, {float(r.beta_ci_hi):.3f}]\", axis=1)\n",
    "display_df[\"r2\"] = display_df[\"r2\"].map(\"{:.4f}\".format)\n",
    "display_df = display_df.drop(columns=[\"beta_ci_lo\",\"beta_ci_hi\"])\n",
    "display_df.columns = [\"股票\",\"行业\",\"α̂\",\"p值\",\"β̂\",\"95%CI\",\"R²\"]\n",
    "print(display_df.to_string(index=False))"
   ]
  },
