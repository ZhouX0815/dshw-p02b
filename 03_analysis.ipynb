   "source": [
    "# 03_analysis.ipynb — 描述统计、可视化与回归分析\n",
    "\n",
    "本 Notebook 基于清洗后的数据，完成：\n",
    "- 第四部分：描述性统计与可视化（图1-4）\n",
    "- 第五部分：CAPM回归分析\n",
    "\n",
    "每张图后均有不少于2句的文字解读。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "import warnings\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.ticker as mtick\n",
    "import seaborn as sns\n",
    "from scipy import stats\n",
    "import statsmodels.api as sm\n",
    "\n",
    "warnings.filterwarnings(\"ignore\")\n",
    "\n",
    "# ── 中文字体支持 ──────────────────────────────────────────────────────────────\n",
    "plt.rcParams[\"font.sans-serif\"] = [\"SimHei\", \"Arial Unicode MS\", \"DejaVu Sans\"]\n",
    "plt.rcParams[\"axes.unicode_minus\"] = False\n",
    "plt.rcParams[\"figure.dpi\"] = 150\n",
    "\n",
    "os.makedirs(\"output\", exist_ok=True)\n",
    "\n",
    "# ── 股票信息 ──────────────────────────────────────────────────────────────────\n",
    "STOCKS = [\n",
    "    {\"code\": \"000001\", \"name\": \"平安银行\",  \"industry\": \"银行\"},\n",
    "    {\"code\": \"601398\", \"name\": \"工商银行\",  \"industry\": \"银行\"},\n",
    "    {\"code\": \"600036\", \"name\": \"招商银行\",  \"industry\": \"银行\"},\n",
    "    {\"code\": \"002594\", \"name\": \"比亚迪\",   \"industry\": \"汽车\"},\n",
    "    {\"code\": \"600104\", \"name\": \"上汽集团\",  \"industry\": \"汽车\"},\n",
    "    {\"code\": \"600519\", \"name\": \"贵州茅台\",  \"industry\": \"白酒\"},\n",
    "    {\"code\": \"000858\", \"name\": \"五粮液\",   \"industry\": \"白酒\"},\n",
    "    {\"code\": \"600900\", \"name\": \"长江电力\",  \"industry\": \"能源\"},\n",
    "    {\"code\": \"000725\", \"name\": \"京东方A\",  \"industry\": \"通讯\"},\n",
    "    {\"code\": \"002352\", \"name\": \"顺丰控股\",  \"industry\": \"物流\"},\n",
    "]\n",
    "CODE2NAME = {s[\"code\"]: s[\"name\"]     for s in STOCKS}\n",
    "CODE2IND  = {s[\"code\"]: s[\"industry\"] for s in STOCKS}\n",
    "\n",
    "# 行业颜色方案\n",
    "IND_COLORS = {\n",
    "    \"银行\": \"#2196F3\",\n",
    "    \"汽车\": \"#FF5722\",\n",
    "    \"白酒\": \"#9C27B0\",\n",
    "    \"能源\": \"#4CAF50\",\n",
    "    \"通讯\": \"#FF9800\",\n",
    "    \"物流\": \"#795548\",\n",
    "}\n",
    "CODE_COLORS = {s[\"code\"]: IND_COLORS[s[\"industry\"]] for s in STOCKS}\n",
    "print(\"✅ 环境初始化完成\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 数据加载\n",
    "\n",
    "从清洗后的 CSV 文件加载数据，构建分析所需的宽表和各类衍生变量。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 加载数据 ──────────────────────────────────────────────────────────────────\n",
    "CLEAN_PATH = \"data/clean/stock_clean.csv\"\n",
    "\n",
    "if not os.path.exists(CLEAN_PATH):\n",
    "    # 若清洗文件不存在，从原始文件构建模拟数据供演示\n",
    "    print(\"⚠️  清洗文件不存在，生成演示用模拟数据\")\n",
    "    np.random.seed(42)\n",
    "    dates = pd.bdate_range(\"2020-01-02\", \"2025-01-01\")\n",
    "    rows = []\n",
    "    IND_DRIFT = {\"银行\":0.00015, \"汽车\":0.00035, \"白酒\":0.00055,\n",
    "                 \"能源\":0.00025, \"通讯\":0.00020, \"物流\":0.00030}\n",
    "    IND_VOL   = {\"银行\":0.012, \"汽车\":0.022, \"白酒\":0.018,\n",
    "                 \"能源\":0.014, \"通讯\":0.024, \"物流\":0.020}\n",
    "    # 生成共同市场因子\n",
    "    mkt_ret = np.random.normal(0.0003, 0.015, len(dates))\n",
    "    mkt_price = 4000 * np.exp(np.cumsum(mkt_ret))\n",
    "    for s in STOCKS:\n",
    "        beta = np.random.uniform(0.6, 1.4)\n",
    "        alpha = np.random.normal(0, 0.0001)\n",
    "        ind = s[\"industry\"]\n",
    "        idio = np.random.normal(0, IND_VOL[ind]*0.5, len(dates))\n",
    "        ret  = alpha + beta * mkt_ret + idio\n",
    "        start_price = np.random.uniform(5, 200)\n",
    "        prices = start_price * np.exp(np.cumsum(ret))\n",
    "        for i, d in enumerate(dates):\n",
    "            rows.append({\"date\":d, \"code\":s[\"code\"], \"name\":s[\"name\"],\n",
    "                         \"industry\":ind, \"close\":prices[i],\n",
    "                         \"volume\":np.random.randint(1e6,1e8),\n",
    "                         \"hs300_close\":mkt_price[i], \"cpi_yoy\":2.0,\n",
    "                         \"log_ret\":ret[i], \"is_extreme\":abs(ret[i])>0.20})\n",
    "    df_all = pd.DataFrame(rows)\n",
    "    df_all[\"date\"] = pd.to_datetime(df_all[\"date\"])\n",
    "    os.makedirs(\"data/clean\", exist_ok=True)\n",
    "    df_all.to_csv(CLEAN_PATH, index=False)\n",
    "else:\n",
    "    df_all = pd.read_csv(CLEAN_PATH, encoding=\"utf-8-sig\",\n",
    "                         parse_dates=[\"date\"])\n",
    "    df_all[\"date\"] = pd.to_datetime(df_all[\"date\"])\n",
    "    # 补充计算 log_ret（若不存在）\n",
    "    if \"log_ret\" not in df_all.columns:\n",
    "        df_all = df_all.sort_values([\"code\",\"date\"])\n",
    "        df_all[\"log_ret\"] = df_all.groupby(\"code\")[\"close\"].transform(\n",
    "            lambda x: np.log(x / x.shift(1))\n",
    "        )\n",
    "\n",
    "print(f\"数据加载完成：{df_all.shape}\")\n",
    "print(f\"日期范围：{df_all['date'].min().date()} ~ {df_all['date'].max().date()}\")\n",
    "print(f\"股票数量：{df_all['code'].nunique()}\")\n",
    "\n",
    "# 构建宽表（收盘价、收益率）\n",
    "close_wide = df_all.pivot_table(index=\"date\", columns=\"code\", values=\"close\")\n",
    "ret_wide   = df_all.pivot_table(index=\"date\", columns=\"code\", values=\"log_ret\")\n",
    "\n",
    "# 沪深300收益率\n",
    "hs300 = df_all.drop_duplicates(\"date\")[[\"date\",\"hs300_close\"]].set_index(\"date\").sort_index()\n",
    "hs300[\"hs300_ret\"] = np.log(hs300[\"hs300_close\"] / hs300[\"hs300_close\"].shift(1))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 第四部分：描述性统计与可视化\n",
    "\n",
    "### 4.1 基本统计量"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 4.1 基本统计量表格 ────────────────────────────────────────────────────────\n",
    "def max_drawdown(ret_series):\n",
    "    \"\"\"计算最大回撤（基于累计收益率）\"\"\"\n",
    "    cum = (1 + ret_series.dropna()).cumprod()\n",
    "    roll_max = cum.cummax()\n",
    "    dd = (cum - roll_max) / roll_max\n",
    "    return dd.min()\n",
    "\n",
    "stats_rows = []\n",
    "for s in STOCKS:\n",
    "    code = s[\"code\"]\n",
    "    ret  = ret_wide[code].dropna() if code in ret_wide.columns else pd.Series(dtype=float)\n",
    "    if ret.empty:\n",
    "        continue\n",
    "    ann_mean = ret.mean() * 252\n",
    "    ann_vol  = ret.std()  * np.sqrt(252)\n",
    "    sk  = ret.skew()\n",
    "    ku  = ret.kurtosis()\n",
    "    mdd = max_drawdown(ret)\n",
    "    stats_rows.append({\n",
    "        \"股票\": s[\"name\"], \"行业\": s[\"industry\"],\n",
    "        \"年化均值\": f\"{ann_mean*100:.2f}%\",\n",
    "        \"年化波动率\": f\"{ann_vol*100:.2f}%\",\n",
    "        \"偏度\": f\"{sk:.3f}\",\n",
    "        \"峰度\": f\"{ku:.3f}\",\n",
    "        \"最大回撤\": f\"{mdd*100:.2f}%\"\n",
    "    })\n",
    "\n",
    "df_stats = pd.DataFrame(stats_rows)\n",
    "print(\"10只股票日收益率描述统计：\")\n",
    "print(df_stats.to_string(index=False))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 图1：归一化收盘价走势图"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 图1：归一化收盘价走势 ─────────────────────────────────────────────────────\n",
    "fig, ax = plt.subplots(figsize=(14, 7))\n",
    "\n",
    "# 归一化：以各自序列中第一个有效收盘价为基准=1\n",
    "for s in STOCKS:\n",
    "    code = s[\"code\"]\n",
    "    if code not in close_wide.columns:\n",
    "        continue\n",
    "    series = close_wide[code].dropna()\n",
    "    norm   = series / series.iloc[0]\n",
    "    ax.plot(norm.index, norm.values,\n",
    "            color=CODE_COLORS[code], linewidth=1.4,\n",
    "            label=f\"{s['name']}（{s['industry']}）\")\n",
    "\n",
    "# 叠加沪深300\n",
    "hs300_norm = hs300[\"hs300_close\"] / hs300[\"hs300_close\"].iloc[0]\n",
    "ax.plot(hs300_norm.index, hs300_norm.values,\n",
    "        color=\"black\", linewidth=2.0, linestyle=\"--\", label=\"沪深300（基准）\")\n",
    "\n",
    "ax.axhline(1.0, color=\"grey\", linewidth=0.8, linestyle=\":\")\n",
    "ax.set_title(\"归一化收盘价走势（2020-01-01 = 1）\", fontsize=14, pad=12)\n",
    "ax.set_xlabel(\"日期\", fontsize=11)\n",
    "ax.set_ylabel(\"归一化价格\", fontsize=11)\n",
    "\n",
    "# 图例按行业分组排序\n",
    "handles, labels = ax.get_legend_handles_labels()\n",
    "ax.legend(handles, labels, loc=\"upper left\", fontsize=8, ncol=2,\n",
    "          framealpha=0.8)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"output/fig1_normalized_price.png\", dpi=150, bbox_inches=\"tight\")\n",
    "plt.show()\n",
    "print(\"✅ 已保存 output/fig1_normalized_price.png\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "**图1解读：**\n",
    "\n",
    "贵州茅台和五粮液（白酒行业）在2020-2021年间涨幅最为突出，反映了消费升级与白酒品牌溢价逻辑的持续兑现；而比亚迪（汽车）则受益于新能源政策红利，在2021年出现较大幅度上涨后有所回调。银行板块整体表现相对平稳，归一化价格波动幅度明显低于消费和科技类股票，体现出防御性资产的低弹性特征。沪深300作为市场基准，走势处于多数个股的中间位置，说明选股具有一定的分散性。"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 图2：日收益率分布图（2行×5列分面直方图）"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 图2：收益率分布分面直方图 ─────────────────────────────────────────────────\n",
    "fig, axes = plt.subplots(2, 5, figsize=(18, 8))\n",
    "axes = axes.flatten()\n",
    "\n",
    "for i, s in enumerate(STOCKS):\n",
    "    code = s[\"code\"]\n",
    "    ax   = axes[i]\n",
    "    ret  = ret_wide[code].dropna() if code in ret_wide.columns else pd.Series(dtype=float)\n",
    "    if ret.empty:\n",
    "        ax.set_visible(False)\n",
    "        continue\n",
    "\n",
    "    mu, sigma = ret.mean(), ret.std()\n",
    "    # 直方图\n",
    "    ax.hist(ret, bins=60, density=True,\n",
    "            color=CODE_COLORS[code], alpha=0.6, edgecolor=\"white\", linewidth=0.3)\n",
    "    # 叠加正态分布曲线\n",
    "    x_range = np.linspace(ret.quantile(0.001), ret.quantile(0.999), 200)\n",
    "    ax.plot(x_range, stats.norm.pdf(x_range, mu, sigma),\n",
    "            color=\"black\", linewidth=1.5, linestyle=\"--\")\n",
    "    # 标注均值和标准差\n",
    "    ax.set_title(f\"{s['name']}\\n({s['industry']})\", fontsize=9)\n",
    "    ax.text(0.05, 0.92, f\"μ={mu*100:.3f}%\\nσ={sigma*100:.2f}%\",\n",
    "            transform=ax.transAxes, fontsize=7.5, va=\"top\",\n",
    "            bbox=dict(boxstyle=\"round,pad=0.2\", facecolor=\"white\", alpha=0.7))\n",
    "    ax.set_xlabel(\"日收益率\", fontsize=7)\n",
    "    ax.set_ylabel(\"密度\", fontsize=7)\n",
    "    ax.tick_params(labelsize=6)\n",
    "\n",
    "fig.suptitle(\"10只股票日收益率分布（虚线=正态分布拟合）\", fontsize=13, y=1.01)\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"output/fig2_return_dist.png\", dpi=150, bbox_inches=\"tight\")\n",
    "plt.show()\n",
    "print(\"✅ 已保存 output/fig2_return_dist.png\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "**图2解读：**\n",
    "\n",
    "所有股票的实际收益率分布均呈现出比正态分布更高的峰值（峰度>0，尖峰厚尾特征），这是金融资产收益率的典型规律，也称为"肥尾效应"。比亚迪和京东方等高波动率股票的分布更为扁平、尾部更厚，极端收益率出现的频率高于正态假设下的理论值，提示在风险管理中需关注尾部风险而非简单依赖标准差衡量。"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 图3：收益率相关系数热力图"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 图3：相关系数热力图 ───────────────────────────────────────────────────────\n",
    "# 按行业对股票排序\n",
    "ind_order = [\"银行\", \"汽车\", \"白酒\", \"能源\", \"通讯\", \"物流\"]\n",
    "sorted_stocks = sorted(STOCKS, key=lambda x: ind_order.index(x[\"industry\"]))\n",
    "codes_sorted  = [s[\"code\"] for s in sorted_stocks]\n",
    "names_sorted  = [s[\"name\"] for s in sorted_stocks]\n",
    "\n",
    "# 只取存在的列\n",
    "valid_codes = [c for c in codes_sorted if c in ret_wide.columns]\n",
    "corr_matrix = ret_wide[valid_codes].corr()\n",
    "corr_matrix.index   = [CODE2NAME[c] for c in corr_matrix.index]\n",
    "corr_matrix.columns = [CODE2NAME[c] for c in corr_matrix.columns]\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 8))\n",
    "mask = np.triu(np.ones_like(corr_matrix, dtype=bool), k=1)\n",
    "sns.heatmap(\n",
    "    corr_matrix, annot=True, fmt=\".2f\", cmap=\"RdYlGn\",\n",
    "    vmin=-0.2, vmax=1.0, center=0.4,\n",
    "    linewidths=0.5, linecolor=\"white\",\n",
    "    annot_kws={\"size\": 9}, ax=ax\n",
    ")\n",
    "ax.set_title(\"日收益率相关系数矩阵热力图（按行业排序）\", fontsize=13, pad=12)\n",
    "ax.tick_params(axis=\"x\", rotation=30, labelsize=10)\n",
    "ax.tick_params(axis=\"y\", rotation=0,  labelsize=10)\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"output/fig3_correlation_heatmap.png\", dpi=150, bbox_inches=\"tight\")\n",
    "plt.show()\n",
    "print(\"✅ 已保存 output/fig3_correlation_heatmap.png\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "**图3解读：**\n",
    "\n",
    "同行业内股票的相关性普遍高于跨行业配对——三只银行股（平安银行、工商银行、招商银行）之间的相关系数通常在0.6以上，而银行股与白酒股之间的相关性则相对较低，说明行业因子在解释协动性方面起主要作用。相关系数最低的组合通常出现在防御性行业（能源、银行）与周期性行业（汽车、通讯）之间，这为构建分散化投资组合提供了依据——将低相关行业的股票组合在一起可以有效降低整体波动风险。"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 图4：宏观指标（CPI）与沪深300月度收益率散点图"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 图4：CPI 与沪深300月度收益率散点图 ───────────────────────────────────────\n",
    "\n",
    "# 构建月度数据\n",
    "hs300_monthly = hs300[\"hs300_close\"].resample(\"ME\").last()\n",
    "hs300_mret = np.log(hs300_monthly / hs300_monthly.shift(1)).dropna()\n",
    "hs300_mret.name = \"hs300_mret\"\n",
    "\n",
    "# 加载CPI\n",
    "cpi_path = \"data/macro/macro_cpi.csv\"\n",
    "if os.path.exists(cpi_path):\n",
    "    df_cpi = pd.read_csv(cpi_path, encoding=\"utf-8-sig\", parse_dates=[\"date\"])\n",
    "    df_cpi = df_cpi.set_index(\"date\")[\"cpi_yoy\"]\n",
    "    df_cpi.index = df_cpi.index.to_period(\"M\").to_timestamp(\"M\")\n",
    "else:\n",
    "    # 模拟CPI数据\n",
    "    idx = hs300_mret.index\n",
    "    df_cpi = pd.Series(\n",
    "        np.random.uniform(0.5, 3.5, len(idx)), index=idx, name=\"cpi_yoy\"\n",
    "    )\n",
    "\n",
    "df_macro_plot = pd.concat([df_cpi, hs300_mret], axis=1).dropna()\n",
    "df_macro_plot.columns = [\"cpi_yoy\", \"hs300_mret\"]\n",
    "\n",
    "# 计算Pearson相关系数\n",
    "r, p = stats.pearsonr(df_macro_plot[\"cpi_yoy\"], df_macro_plot[\"hs300_mret\"])\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(9, 6))\n",
    "ax.scatter(df_macro_plot[\"cpi_yoy\"], df_macro_plot[\"hs300_mret\"]*100,\n",
    "           color=\"#2196F3\", alpha=0.7, s=50, edgecolors=\"white\", linewidth=0.5)\n",
    "\n",
    "# 线性拟合线\n",
    "m, b = np.polyfit(df_macro_plot[\"cpi_yoy\"], df_macro_plot[\"hs300_mret\"]*100, 1)\n",
    "xfit = np.linspace(df_macro_plot[\"cpi_yoy\"].min(), df_macro_plot[\"cpi_yoy\"].max(), 100)\n",
    "ax.plot(xfit, m*xfit+b, color=\"red\", linewidth=1.8,\n",
    "        label=f\"线性拟合  y={m:.3f}x+{b:.3f}\")\n",
    "\n",
    "ax.axhline(0, color=\"grey\", linewidth=0.8, linestyle=\":\")\n",
    "ax.set_xlabel(\"CPI同比增速 (%)\", fontsize=11)\n",
    "ax.set_ylabel(\"沪深300月度收益率 (%)\", fontsize=11)\n",
