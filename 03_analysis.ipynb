    "print(\"  这与'周期性 vs 防御性'行业分类高度吻合：\")\n",
    "print(\"  周期股（汽车/科技）β 普遍>1，防御股（银行/能源）β 倾向≤1。\")\n",
    "print()\n",
    "print(\"=\"*60)\n",
    "if sig_alpha.empty:\n",
    "    print(\"问题2：Alpha显著性\")\n",
    "    print(\"  所有股票的 α̂ 均不显著（p>0.05），\")\n",
    "    print(\"  说明在市场因子之外无法确认系统性超额收益。\")\n",
    "    print(\"  这符合市场有效性假说（弱式有效市场）：\")\n",
    "    print(\"  股价已充分反映历史信息，历史超额收益不可持续。\")\n",
